# Firebase (Vite environment variables must be prefixed with VITE_)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX


# Example: create a local file named .env.local and fill values above
# Do NOT commit real keys to version control.
# Backend API URL
VITE_API_URL=http://localhost:8000

# Gemini API Key (FastAPI backend only)
GEMINI_API_KEY=your_gemini_api_key_here
