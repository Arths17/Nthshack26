# Example environment variables for running the backend locally or on Vercel.
# Copy this to .env.local (do NOT commit .env.local with real secrets).

# Comma-separated list of allowed origins for CORS (frontend URLs).
# For Vercel, set to your deployment domain: https://your-project.vercel.app
ALLOWED_ORIGINS=

# Vercel automatically provides VERCEL_URL for the deployment (no need to set it).

# Gemini API key (required for strategy parsing/chat features)
GEMINI_API_KEY=

# Optional: allowlist of other origins, e.g. local dev URLs
# ALLOWED_ORIGINS=http://localhost:3000,https://your-project.vercel.app
# Firebase (Next.js environment variables)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX


# Example: create a local file named .env.local and fill values above
# Do NOT commit real keys to version control.

# Optional: allow email/password sign-in without Firebase (localStorage only). Use for quick local UI tests.
# In `next dev`, this is automatic when Firebase vars are missing. Set to true for `next start` without Firebase.
# NEXT_PUBLIC_AUTH_DEV_LOCAL=true

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Gemini API Key (FastAPI backend only)
GEMINI_API_KEY=your_gemini_api_key_here
